FROM python:3.12-slim
WORKDIR /app
RUN pip install --no-cache-dir uv
COPY whatsapp-mcp-server/pyproject.toml .
RUN uv pip install --system \
    "httpx>=0.28.1" \
    "mcp[cli]>=1.10.0,<1.20.0" \
    "requests>=2.32.3" \
    "uvicorn>=0.34.0" \
    "starlette>=0.46.0"
COPY whatsapp-mcp-server/ .

ENV MCP_TRANSPORT=sse
ENV PORT=8000
ENV WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:8080
ENV WHATSAPP_DB_PATH=/app/store/messages.db

EXPOSE 8000
CMD ["python", "main.py"]
